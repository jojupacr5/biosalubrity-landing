---
import { Image } from 'astro:assets';

import logo from '../../assets/images/logo.png';

// Importar las traducciones según el idioma actual
import en from '../../locales/en.json';
import es from '../../locales/es.json';

const locale = Astro.currentLocale || 'es';
const translations = locale === 'en' ? en : es;
---

<nav class="fixed left-0 right-0 top-0 z-50 bg-white">
  <div class="w-full max-w-7xl mx-auto flex items-center justify-between py-4 px-4 md:px-6">
    <a href="#inicio">
      <Image class="h-10 lg:h-14 xl:h-16 w-auto" src={logo} alt="Logo de la empresa"></Image>
    </a>

    <!-- Hamburger Button - Visible only on sm and md -->
    <button
      id="hamburger-btn"
      class="lg:hidden flex flex-col gap-1 cursor-pointer p-2"
      aria-label="Toggle menu"
    >
      <span class="hamburger-line w-6 h-0.5 bg-gray-800 transition-all duration-300"></span>
      <span class="hamburger-line w-6 h-0.5 bg-gray-800 transition-all duration-300"></span>
      <span class="hamburger-line w-6 h-0.5 bg-gray-800 transition-all duration-300"></span>
    </button>

    <!-- Desktop Menu - Hidden on sm and md -->
    <div class="hidden lg:block text-poppins">
      <ul class="flex items-center gap-10 text-base lg:text-base xl:text-lg font-medium tracking-wide">
        <li><a href="#inicio" class="hover:text-blue-600 transition-colors">{locale === 'en' ? translations.nav.home : translations.nav.inicio}</a></li>
        <li><a href="#historia" class="hover:text-blue-600 transition-colors">{locale === 'en' ? translations.nav.history : translations.nav.historia}</a></li>
        <li><a href="#reconocimiento" class="hover:text-blue-600 transition-colors">{locale === 'en' ? translations.nav.recognition : translations.nav.reconocimiento}</a></li>
        <li>
          <a class="flex items-center btn" href="#afiliate">
            {translations.nav.afiliate}
            <svg fill="#ffffff" version="1.1" class="h-4 pl-1" id="Capa_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 123.97 123.97" xml:space="preserve" stroke="#ffffff"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <g> <path d="M27.961,99.367c-5.8,5.8,-5.7,15.3,0.5,20.899c5.8,5.301,14.8,4.801,20.3,-0.8l47.3,-47.3c2.8,-2.8,4.2,-6.5,4.2,-10.2 s-1.4,-7.399,-4.2,-10.2l-47.2,-47.3c-5.5,-5.5,-14.6,-6.1,-20.3,-0.8c-6.1,5.6,-6.3,15.1,-0.5,20.9l30.2,30.399c3.9,3.9,3.9,10.2,0,14.101 L27.961,99.367z"></path> </g> </g></svg>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Mobile Menu - Visible only on sm and md -->
  <div
    id="mobile-menu"
    class="fixed right-0 top-0 w-64 h-screen bg-white shadow-lg transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden z-40 overflow-y-auto"
  >
    <!-- Close Button -->
    <div class="flex justify-end p-4 border-b border-gray-200">
      <button
        id="close-menu-btn"
        class="text-gray-800 hover:text-gray-600 transition-colors"
        aria-label="Close menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="text-poppins p-6">
      <ul class="flex flex-col text-center gap-6 text-base font-medium tracking-wide">
        <li>
          <a href="#inicio" class="block text-gray-800 hover:text-blue-600 transition-colors" onclick="document.getElementById('mobile-menu').classList.add('translate-x-full'); document.getElementById('menu-backdrop').classList.add('hidden');">
            {locale === 'en' ? translations.nav.home : translations.nav.inicio}
          </a>
        </li>
        <li>
          <a href="#historia" class="block text-gray-800 hover:text-blue-600 transition-colors" onclick="document.getElementById('mobile-menu').classList.add('translate-x-full'); document.getElementById('menu-backdrop').classList.add('hidden');">
            {locale === 'en' ? translations.nav.history : translations.nav.historia}
          </a>
        </li>
        <li>
          <a href="#reconocimiento" class="block text-gray-800 hover:text-blue-600 transition-colors" onclick="document.getElementById('mobile-menu').classList.add('translate-x-full'); document.getElementById('menu-backdrop').classList.add('hidden');">
            {locale === 'en' ? translations.nav.recognition : translations.nav.reconocimiento}
          </a>
        </li>
        <li>
          <a class="flex items-center btn w-fit mx-auto" href="#afiliate" onclick="document.getElementById('mobile-menu').classList.add('translate-x-full'); document.getElementById('menu-backdrop').classList.add('hidden');">
            {translations.nav.afiliate} 
            <svg fill="#ffffff" version="1.1" class="h-4 pl-1" id="Capa_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 123.97 123.97" xml:space="preserve" stroke="#ffffff"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <g> <path d="M27.961,99.367c-5.8,5.8-5.7,15.3,0.5,20.899c5.8,5.301,14.8,4.801,20.3-0.8l47.3-47.3c2.8-2.8,4.2-6.5,4.2-10.2 s-1.4-7.399-4.2-10.2l-47.2-47.3c-5.5-5.5-14.6-6.1-20.3-0.8c-6.1,5.6-6.3,15.1-0.5,20.9l30.2,30.399c3.9,3.9,3.9,10.2,0,14.101 L27.961,99.367z"></path> </g> </g></svg>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Overlay backdrop for mobile menu -->
  <div
    id="menu-backdrop"
    class="hidden fixed inset-0 bg-black/40 lg:hidden z-30 transition-opacity duration-300"
    onclick="document.getElementById('mobile-menu').classList.add('translate-x-full'); document.getElementById('menu-backdrop').classList.add('hidden');"
  ></div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hamburgerBtn = document.getElementById('hamburger-btn');
    const closeMenuBtn = document.getElementById('close-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuBackdrop = document.getElementById('menu-backdrop');

    const closeMenu = () => {
      mobileMenu?.classList.add('translate-x-full');
      menuBackdrop?.classList.add('hidden');
    };

    const openMenu = () => {
      mobileMenu?.classList.remove('translate-x-full');
      menuBackdrop?.classList.remove('hidden');
    };

    if (hamburgerBtn && mobileMenu && menuBackdrop && closeMenuBtn) {
      hamburgerBtn.addEventListener('click', () => {
        const isClosed = mobileMenu.classList.contains('translate-x-full');
        isClosed ? openMenu() : closeMenu();
      });

      closeMenuBtn.addEventListener('click', closeMenu);
    }
  });
</script>
