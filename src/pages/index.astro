---
import { Image } from 'astro:assets';

import Layout from '../layouts/Layout.astro';

import Protegemos from '../assets/icons/protegemos.svg';
import Verificamos from '../assets/icons/verificamos.svg';
import Certificamos from '../assets/icons/certificamos.svg';
import People from '../assets/icons/people.svg';
import Heart from '../assets/icons/heart-health.svg';
import Person from '../assets/icons/person.svg';
import Analithics from '../assets/icons/analytics.svg';
import PwcLogo from '../assets/icons/PwC-logo.svg';
import Gob from '../assets/icons/gob.svg';
import Handshake from '../assets/icons/handshake.svg';

import heroBg from '../assets/images/hero-bg.png';
import minsaLogo from '../assets/images/minsa-logo.png';
import congresoLogo from '../assets/images/congreso-logo.png';
import afiliateMobile from '../assets/images/afiliate-mobile.png';
import afiliateDesktop from '../assets/images/afiliate-desktop.png';
---

<Layout>

	<section id="inicio" class="mt-16 md:mt-18 lg:mt-22 xl:mt-24">
		<div class="max-w-7xl mx-auto px-4 md:px-6 pt-8 md:py-28 lg:py-20">
			<div class="flex flex-col md:max-w-1/2 lg:max-w-110 font-poppins">
				<h1 class="tracking-wider md:tracking-wide leading-normal md:leading-snug text-3xl lg:text-5xl font-black bg-linear-(--linear-title) bg-clip-text text-transparent mb-6 md:mb-2">
					En los momentos más críticos, la seguridad sanitaria no fue una opción, fue la solución.
				</h1>
				<p class="text-base leading-relaxed md:text-lg font-medium mb-6">Biosalubrity nació en plena pandemia para proteger vidas, apoyar a los estrablecimientos y reactivar la economía con confianza.</p>
				<div class="mb-0 lg:mb-6">
					<a href="#historia" class="btn w-fit flex items-center px-3">
						Conoce nuestra historia 
						<svg fill="#ffffff" version="1.1" class="h-4 pl-1" id="Capa_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 123.97 123.97" xml:space="preserve" stroke="#ffffff"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <g> <path d="M27.961,99.367c-5.8,5.8-5.7,15.3,0.5,20.899c5.8,5.301,14.8,4.801,20.3-0.8l47.3-47.3c2.8-2.8,4.2-6.5,4.2-10.2 s-1.4-7.399-4.2-10.2l-47.2-47.3c-5.5-5.5-14.6-6.1-20.3-0.8c-6.1,5.6-6.3,15.1-0.5,20.9l30.2,30.399c3.9,3.9,3.9,10.2,0,14.101 L27.961,99.367z"></path> </g> </g></svg>
					</a>	
				</div>
				<p class="hidden lg:block text-lg font-medium">Seguridad sanitaria para un mundo <span class="text-complementary">más seguro.</span></p>
			</div>
			<div class="md:hidden relative h-80 w-screen left-1/2 right-1/2 mx-[-50vw]">
				<Image class="w-full h-full object-cover object-bottom-right" src={heroBg} alt="Imagen de seguridad sanitaria"></Image>
				<div class="absolute inset-x-0 top-0 h-1/3 bg-linear-to-b from-white to-transparent pointer-events-none"></div>
			</div>
		</div>
	</section>

	<section id="servicios" class="max-w-7xl w-auto mx-auto px-4 mb-12 lg:-mt-10 lg:mb-20">
		<div class="bg-white rounded-xl shadow-md">
			<div class="flex flex-col md:flex-row justify-center items-start lg:items-center flex-wrap py-4 lg:py-0">
				<div class="servicio flex items-center md:w-75 p-4 lg:py-5 lg:px-10">
					<Protegemos class="h-16 w-auto mr-4"/>
					<div>
						<h3 class="uppercase text-lg font-bold">PROTEGEMOS</h3>
						<p class="text-base lg:max-w-30">Personas y establecimientos</p>
					</div>
				</div>
				<div class="hidden lg:block h-16 w-0.5 bg-slate-200"></div>
				<div class="servicio flex items-center md:w-75 p-4 lg:py-5 lg:px-10">
					<Verificamos class="h-16 w-auto mr-4" />
					<div>
						<h3 class="uppercase text-lg font-bold">Verificamos</h3>
						<p class="text-base lg:max-w-30">Cumplimiento de protocoles</p>
					</div>
				</div>
				<div class="hidden lg:block h-16 w-0.5 bg-slate-200"></div>
				<div class="servicio flex items-center md:w-75 p-4 lg:py-5 lg:px-10">
					<Certificamos class="h-16 w-auto mr-4"/>
					<div>
						<h3 class="uppercase text-lg font-bold">Certificamos</h3>
						<p class="text-base lg:max-w-30">Con sellos confiables</p>
					</div>
				</div>
				<div class="hidden lg:block h-16 w-0.5 bg-slate-200"></div>
				<div class="servicio flex items-center md:w-75 p-4 lg:py-5 lg:px-10">
					<People class="h-16 w-auto mx-4 lg:ml-0"/>
					<div>
						<h3 class="uppercase text-lg font-bold">Cuidamos</h3>
						<p class="text-base lg:max-w-40">La salud pública y la reactividad económica</p>
					</div>
				</div>
			</div>
		</div>
		
	</section>

	<section id="historia" class="max-w-7xl mx-auto bg-white rounded-xl py-12 lg:py-16 px-4 lg:px-10 mb-12 lg:mb-20">
		<h2 class="tracking-wide text-3xl font-black bg-linear-(--linear-btns) bg-clip-text text-transparent mb-4 text-center font-poppins">
			Nacimos cuando más se necesitaba
		</h2>
		<p class="text-base lg:text-lg text-center font-inter mb-10">Marzo 2020. El mundo se detuvo. Nosotros decidimos actuar.</p>
		<div class="flex flex-col md:flex-row justify-center items-center gap-5 flex-wrap">
			<div class="flex md:max-w-75 lg:max-w-64 flex-col items-center justify-center p-5 border border-slate-200 rounded-xl shadow">
				<Heart class="h-20 w-auto mb-0 lg:mb-4"/>
				<div class="h-0.5 w-16 bg-slate-200 my-2"></div>
				<div class="text-center">
					<h3 class="uppercase text-4xl font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">~40MIL</h3>
					<p class="uppercase text-lg font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">Vidas</p>
					<p class="uppercase text-lg font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">Preservadas</p>
					<p class="text-base font-inter">de forma preventiva en el momento que no había vacunas en el mundo.</p>
				</div>
			</div>
			<div class="flex md:max-w-75 lg:max-w-64 flex-col items-center justify-center p-5 border border-slate-200 rounded-xl shadow">
				<Protegemos class="h-20 w-auto mb-0 lg:mb-4"/>
				<div class="h-0.5 w-10 bg-slate-200 my-2"></div>
				<div class="text-center">
					<h3 class="uppercase text-4xl font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">miles</h3>
					<p class="uppercase text-lg font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">de establecimientos</p>
					<p class="uppercase text-lg font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">protegidos</p>
					<p class="text-base font-inter">de diversos rubros implementando protocolos de bioseguridad.</p>
				</div>
			</div>
			<div class="flex md:max-w-75 lg:max-w-64 flex-col items-center justify-center p-5 border border-slate-200 rounded-xl shadow">
				<Person class="h-20 w-auto mb-0 lg:mb-4"/>
				<div class="h-0.5 w-10 bg-slate-200 my-2"></div>
				<div class="text-center">
					<h3 class="uppercase text-4xl font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">millones</h3>
					<p class="uppercase text-lg font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">de personas</p>
					<p class="uppercase text-lg font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">atendidas</p>
					<p class="text-base font-inter">en espacios más seguros gracias a nuestra plataforma y certificación.</p>
				</div>
			</div>
			<div class="flex md:max-w-75 lg:max-w-64 flex-col items-center justify-center p-5 border border-slate-200 rounded-xl shadow">
				<Analithics class="h-20 w-auto mb-0 lg:mb-4"/>
				<div class="h-0.5 w-10 bg-slate-200 my-2"></div>
				<div class="text-center">
					<h3 class="uppercase text-4xl font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">impulsamos</h3>
					<p class="uppercase text-lg font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">La reactivación</p>
					<p class="uppercase text-lg font-bold bg-linear-(--linear-title) bg-clip-text text-transparent">Económica</p>
					<p class="text-base font-inter">generando confianza y contribuyendo a la recuperación del país.</p>
				</div>
			</div>
		</div>
	</section>

	<section id="reconocimiento" class="max-w-7xl mx-auto bg-white rounded-xl py-12 lg:py-16 px-4 lg:px-10 mb-12 lg:mb-20">
		<h2 class="tracking-wide text-3xl font-black bg-linear-(--linear-btns) bg-clip-text text-transparent my-4 text-center font-poppins">
			Reconocimientos que respaldan nuestro impacto
		</h2>
		<div class="flex flex-col md:flex-row justify-center items-center md:items-start flex-wrap md:gap-5">
			<div class="flex items-start justify-start md:max-w-75 lg:max-w-64 p-4 lg:p-5">
				<div class="p-4 mr-4 rounded-full border-2 border-complementary">
					<Verificamos class="h-12 lg:h-16 -mt-1 fill-complementary"/>
				</div>
				<div class="text-left w-auto lg:max-w-40">
					<h3 class="uppercase text-lg font-bold text-slate-800">
						Finalistas Premio de creatividad empresarial
					</h3>
					<p class="text-sm font-inter">Auditado por: Price Waterhouse Coopers</p>
					<PwcLogo class="w-16 h-auto" />
				</div>
			</div>
			<div class="flex items-start justify-start md:max-w-75 lg:max-w-64 p-4 lg:p-5">
				<div class="p-4 mr-4 rounded-full border-2 border-complementary">
					<People class="h-12 lg:h-16 -mt-1"/>
				</div>
				<div class="text-left w-auto lg:max-w-40">
					<h3 class="uppercase text-lg font-bold text-slate-800">
						Plataforma aprobada
					</h3>
					<p class="text-sm font-inter">Por médicos de inteligencia sanitaria del MINSA</p>
					<Image class="w-36 h-auto" src={minsaLogo} alt="Logo del MINSA"></Image>
				</div>
			</div>
			<div class="flex items-start justify-start md:max-w-75 lg:max-w-64 p-4 lg:p-5">
				<div class="p-4 mr-4 rounded-full border-2 border-complementary">
					<Gob class="h-12 lg:h-16 -mt-1"/>
				</div>
				<div class="text-left w-auto lg:max-w-40">
					<h3 class="uppercase text-lg font-bold text-slate-800">
						Reconocidos por el congreso de la republica
					</h3>
					<Image class="h-20 lg:h-24 w-auto" src={congresoLogo} alt="Logo del MINSA"></Image>
				</div>
			</div>
			<div class="flex items-start justify-start md:max-w-75 lg:max-w-64 p-4 lg:p-5">
				<div class="p-4 mr-4 rounded-full border-2 border-complementary">
					<Handshake class="h-12 lg:h-16 w-12 lg:w-16"/>
				</div>
				<div class="text-left w-auto lg:max-w-40">
					<h3 class="uppercase text-lg font-bold text-slate-800">
						Plataforma aprobada
					</h3>
					<p class="text-sm font-inter">Reconocidos contra covid y por promover la reactivación económica</p>
				</div>
			</div>
		</div>
	</section>

	<section id="afiliate" class=" max-w-7xl w-full px-4 h-auto mb-4 lg:mb-12 mx-auto">
		<div class="relative w-full rounded-2xl p-4 md:max-w-7/12 lg:max-w-none lg:py-32 lg:px-10 lg:mb-20 md:mx-auto">
			<h3 class="tracking-wide text-white text-2xl md:text-3xl font-black my-4 text-left font-poppins max-w-120 leading-snug">
				Transformamos un momento de crisis en un legado de prevención y confianza
			</h3>
			<p class="max-w-112.5 text-base md:text-xl text-white mb-96 lg:mb-6">
				Biosalubrity no solo fue parte de la solución, fue un actor clave para salvar vidas y construir un futuro más seguro.
			</p>
			<div class="hidden lg:block">
				<a  href="#historia" class="flex items-center justify-center bg-linear-(--linear-btns) w-50 py-3 px-4 text-white rounded-full">
					Se parte del cambio
					<svg fill="#ffffff" version="1.1" class="h-4 pl-1" id="Capa_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 123.97 123.97" xml:space="preserve" stroke="#ffffff"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <g> <path d="M27.961,99.367c-5.8,5.8-5.7,15.3,0.5,20.899c5.8,5.301,14.8,4.801,20.3-0.8l47.3-47.3c2.8-2.8,4.2-6.5,4.2-10.2 s-1.4-7.399-4.2-10.2l-47.2-47.3c-5.5-5.5-14.6-6.1-20.3-0.8c-6.1,5.6-6.3,15.1-0.5,20.9l30.2,30.399c3.9,3.9,3.9,10.2,0,14.101 L27.961,99.367z"></path> </g> </g></svg>
				</a>	
			</div>
			<div class="absolute inset-x-0 top-0 h-1/5 bg-linear-to-b from-black/40 to-transparent pointer-events-none rounded-xl"></div>
		</div>
	</section>

	<div class="block mx-auto mt-8 mb-16 lg:hidden text-center">
		<a  href="#historia" class="mx-auto flex items-center justify-center bg-linear-(--linear-btns) w-56 py-3 px-4 text-white rounded-full font-bold">
			Se parte del cambio
			<svg fill="#ffffff" version="1.1" class="h-4 pl-1" id="Capa_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 123.97 123.97" xml:space="preserve" stroke="#ffffff"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <g> <path d="M27.961,99.367c-5.8,5.8-5.7,15.3,0.5,20.899c5.8,5.301,14.8,4.801,20.3-0.8l47.3-47.3c2.8-2.8,4.2-6.5,4.2-10.2 s-1.4-7.399-4.2-10.2l-47.2-47.3c-5.5-5.5-14.6-6.1-20.3-0.8c-6.1,5.6-6.3,15.1-0.5,20.9l30.2,30.399c3.9,3.9,3.9,10.2,0,14.101 L27.961,99.367z"></path> </g> </g></svg>
		</a>	
	</div>
</Layout>

<style define:vars={{ 
	heroUrl: `url(${heroBg.src})`, 
	afiliateDesktop: `url(${afiliateDesktop.src},)`,
	afiliateMobile: `url(${afiliateMobile.src})`
}}>
#inicio {
	background-color: white;
	scroll-margin-top: 100px;
}

#historia {
	scroll-margin-top: 100px;
}

#afiliate > div:first-of-type {
	background-image: var(--afiliateMobile);
	background-size: cover;
	background-position: center;
	background-repeat: no-repeat;
	scroll-margin-top: 100px;
}

#reconocimiento {
	scroll-margin-top: 80px;
}

@media (width >= 48rem) { 
	#inicio {
		background-image: var(--heroUrl);
		background-size: cover;
	}
}

@media (width >= 64rem) { 
	#reconocimiento {
		scroll-margin-top: 100px;
	}
	#afiliate > div:first-of-type {
		background-image: var(--afiliateDesktop);
		background-size: cover;
	}
}
</style>